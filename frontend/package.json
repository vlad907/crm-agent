{
  "name": "crm-frontend",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build && node scripts/prepare-standalone.cjs",
    "start": "next start",
    "electron:dev": "concurrently -k \"next dev -H 127.0.0.1 -p 3000\" \"wait-on http://127.0.0.1:3000 && cross-env ELECTRON_DEV=1 electron .\"",
    "electron:build": "next build && node scripts/prepare-standalone.cjs && electron-builder"
  },
  "build": {
    "appId": "com.crmcommand.desktop",
    "productName": "CRM Command",
    "directories": {
      "output": "electron-dist"
    },
    "files": [
      "electron/**/*",
      "public/**/*",
      ".next/**/*",
      "next.config.mjs",
      "package.json",
      "package-lock.json"
    ],
    "asar": false,
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.venv/**",
          "!**/venv/**"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.business",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "zip"]
    },
    "linux": {
      "target": ["AppImage", "zip"]
    }
  },
  "dependencies": {
    "@types/leaflet": "^1.9.21",
    "leaflet": "^1.9.4",
    "leaflet-defaulticon-compatibility": "^0.1.2",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-leaflet": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "20.14.12",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "concurrently": "9.1.2",
    "cross-env": "7.0.3",
    "electron": "33.2.1",
    "electron-builder": "25.1.8",
    "typescript": "5.5.4",
    "wait-on": "8.0.1"
  }
}
