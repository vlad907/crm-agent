# Optional. Web dev: set to talk to FastAPI directly (needs CORS for your origin).
# Leave unset to use Next.js /api/v1 → proxy (recommended for Electron).
# NEXT_PUBLIC_API_BASE=http://localhost:8000
# Where Next proxies /api/v1 (Docker: http://backend:8000)
# CRM_API_PROXY_TARGET=http://127.0.0.1:8000
# SSR / server-only fallback when NEXT_PUBLIC_API_BASE is unset
# CRM_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_WORKSPACE_ID=
NEXT_PUBLIC_USER_ID=
